{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "backend/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "prisma/generated/*.node",
        "outDir": "dist/backend/src/",
        "watchAssets": false
      }
    ]
  }
}
