generator client {
    provider     = "prisma-client-js"
    moduleFormat = "esm"
    output       = "../../prisma-client/generated"
}

datasource db {
    provider = "postgresql"
}

model User {
    username String @unique
    password String
}

model Bot {
    id            String     @id
    clusterNumber Int
    shards        Int
    clusters      Cluster[]
}

enum ClusterStatus {
    STARTING
    RUNNING
    STOPPED
    UPDATING
    ERROR
}

model Cluster {
    id    String @id @default(uuid())
    botId String
    containerId String?
    status ClusterStatus
    shardIds Int[]
    bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)
}
