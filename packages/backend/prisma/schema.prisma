generator client {
    provider     = "prisma-client"
    output       = "../src/prisma/generated"
    moduleFormat = "esm"
}

datasource db {
    provider = "postgresql"
}

model Bot {
    id            String     @id
    clusterNumber Int
    shards        Int
    clusters      Cluster[]
}

enum ClusterStatus {
    STARTING
    RUNNING
    STOPPED
    ERROR
}

model Cluster {
    id    String @id @default(uuid())
    botId String

    containerId String?

    status ClusterStatus

    shardIds Int[]

    bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)
}
